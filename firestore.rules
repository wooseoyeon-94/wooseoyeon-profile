rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && 
             (request.auth.token.email == 'jm01hyj@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Profile Rules
    match /profile/{profileId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProfile(incoming());
    }

    function isValidProfile(data) {
      return data.nameKo is string && data.nameKo.size() <= 100 &&
             data.nameEn is string && data.nameEn.size() <= 100 &&
             (!('tagline' in data) || (data.tagline is string && data.tagline.size() <= 500)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('height' in data) || (data.height is string && data.height.size() <= 20)) &&
             (!('weight' in data) || (data.weight is string && data.weight.size() <= 20)) &&
             (!('shoeSize' in data) || (data.shoeSize is string && data.shoeSize.size() <= 20)) &&
             (!('instagram' in data) || (data.instagram is string && data.instagram.size() <= 200)) &&
             (!('mainImageUrl' in data) || (data.mainImageUrl is string && data.mainImageUrl.size() <= 1048576)) &&
             (!('aboutImageUrl' in data) || (data.aboutImageUrl is string && data.aboutImageUrl.size() <= 1048576)) &&
             (!('pdfUrl' in data) || (data.pdfUrl is string && data.pdfUrl.size() <= 500)) &&
             (!('galleryImages' in data) || (data.galleryImages is list && data.galleryImages.size() <= 5));
    }

    // Works Rules
    match /works/{workId} {
      allow read: if true;
      allow create, update: if isValidWork(incoming());
      allow delete: if true;
    }

    function isValidWork(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.year is string && data.year.size() <= 20 &&
             (!('genre' in data) || (data.genre is string && data.genre.size() <= 100)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1048576)) &&
             (!('imageUrls' in data) || (data.imageUrls is list && data.imageUrls.size() <= 3)) &&
             (!('characterDescription' in data) || (data.characterDescription is string && data.characterDescription.size() <= 2000));
    }

    // Testimonials Rules
    match /testimonials/{testId} {
      allow read: if true;
      allow create, update: if isValidTestimonial(incoming());
      allow delete: if true;
    }

    function isValidTestimonial(data) {
      return data.quote is string && data.quote.size() <= 1000 &&
             data.author is string && data.author.size() <= 100;
    }

    // Assets Rules
    match /assets/{assetId} {
      allow read: if true;
      allow create, update: if isValidAsset(incoming());
      allow delete: if true;
    }

    function isValidAsset(data) {
      return data.category in ['tops', 'bottoms', 'shoes', 'others'] &&
             data.name is string && data.name.size() <= 200 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1048576)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000));
    }
  }
}
